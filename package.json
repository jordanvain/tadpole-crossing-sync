{
  "name": "tadpole-crossing-sync",
  "version": "0.1.0",
  "description": "Automated sync between Ricochet Consignment and Wave Accounting for Tadpole Crossing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "export": "ts-node src/index.ts export",
    "transform": "ts-node src/index.ts transform",
    "sync": "ts-node src/index.ts sync",
    "sync:dry": "ts-node src/index.ts sync --dry-run",
    "status": "ts-node src/index.ts status"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "playwright": "^1.49.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
